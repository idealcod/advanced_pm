APP_ENV=production
PORT=8080
LOG_FORMAT=text
LOG_LEVEL=info

# Use DATABASE_URL on Render, for example from Neon, Supabase, or Render Postgres.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/ramadan_arc?sslmode=require

# Docker Compose/local Postgres alternative.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ramadan_arc
POSTGRES_SSLMODE=disable

# Optional. If empty, backend uses an in-process event bus.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_STREAM=ramadan_arc_events

JWT_SECRET=change_me_to_at_least_32_characters
JWT_TTL_HOURS=24

# Comma-separated allowed browser origins for CORS.
FRONTEND_ORIGIN=http://localhost:3000

# Optional AI lesson feedback.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30
DB_CONN_MAX_IDLE_MINUTES=5
